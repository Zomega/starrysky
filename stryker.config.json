{
  "$schema": "https://stryker-mutator.io/schema/stryker-config.json",
  "mutate": [
    "mockup.js",
    "service/src/core/*.ts",
    "service/src/core/providers/*.ts",
    "service/src/mock-data.js"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "npx tsx --test tests/*.test.ts"
  },
  "reporters": ["progress", "clear-text", "html"],
  "concurrency": 2,
  "timeoutMS": 30000
}
